HOST=0.0.0.0
PORT=8080
LAB_DATA_DIR=/app/data

# Optional: set one ingress profile here instead of passing --profile every time.
# Valid values: caddy, cloudflare. Leave empty for app internals only.
# COMPOSE_PROFILES=caddy

# Optional Cloudflare Tunnel deployment (docker-compose.yaml service: cloudflared)
# Create a tunnel in Cloudflare Zero Trust and paste the Docker connector token here.
CLOUDFLARED_TUNNEL_TOKEN=
CLOUDFLARED_VERSION=latest
